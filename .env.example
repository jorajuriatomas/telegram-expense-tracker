# Top-level environment file consumed by docker-compose.yml.
# Copy to `.env` and fill in real values.
# --- Postgres ---
POSTGRES_DB=expenses
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
# Optional: comma-separated list of telegram_ids to seed the `users` whitelist
# on first DB init. Examples:
#   INITIAL_TELEGRAM_IDS=1218557035
#   INITIAL_TELEGRAM_IDS=1218557035,9876543210,5555555555
# Leave blank to skip; add users manually with:
#   INSERT INTO users ("telegram_id") VALUES ('...');
INITIAL_TELEGRAM_IDS=

# --- Bot Service (Python) ---
BOT_SERVICE_PORT=8000
# LLM provider — any LangChain-supported provider works.
# Examples:
#   openai        + gpt-4o-mini                 (paid)
#   google_genai  + gemini-2.0-flash            (free tier, recommended)
#   anthropic     + claude-3-5-haiku-latest     (paid, free credits)
#   groq          + llama-3.3-70b-versatile     (free tier)
LLM_PROVIDER=google_genai
LLM_MODEL_NAME=gemini-2.0-flash
LLM_API_KEY=replace-me
LOG_LEVEL=INFO

# --- Connector Service (Node) ---
CONNECTOR_PORT=3000
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_SECRET=replace-me
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_API_BASE_URL=https://api.telegram.org
BOT_SERVICE_PROCESS_MESSAGE_PATH=/process-message
