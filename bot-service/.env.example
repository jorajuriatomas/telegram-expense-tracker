BOT_SERVICE_HOST=0.0.0.0
BOT_SERVICE_PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/expenses
# Pick any LangChain-supported provider. See top-level .env.example for options.
LLM_PROVIDER=google_genai
LLM_MODEL_NAME=gemini-2.0-flash
LLM_API_KEY=replace-me
LOG_LEVEL=INFO
# Optional comma-separated list of telegram_ids seeded into the whitelist
# at startup. Leave empty to skip; non-numeric tokens are ignored.
INITIAL_TELEGRAM_IDS=
